{
  "info": {
    "name": "Connect Flow API",
    "description": "Complete API collection for Connect Flow Gold Pawn Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "    pm.environment.set(\"authToken\", jsonData.token);",
                  "    console.log(\"Token saved:\", jsonData.token.substring(0, 20) + \"...\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@connectflow.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login to get JWT token. Token will be automatically saved to collection variable."
          },
          "response": []
        },
        {
          "name": "Login as Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@connectflow.com\",\n  \"password\": \"Manager@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Login as Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authToken\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@connectflow.com\",\n  \"password\": \"Staff@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Item Types",
      "item": [
        {
          "name": "Get All Item Types",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/item-types",
              "host": ["{{baseUrl}}"],
              "path": ["item-types"]
            },
            "description": "Get all item types (active and inactive)"
          },
          "response": []
        },
        {
          "name": "Get Active Item Types",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/item-types/active",
              "host": ["{{baseUrl}}"],
              "path": ["item-types", "active"]
            },
            "description": "Get only active item types"
          },
          "response": []
        },
        {
          "name": "Get Item Type by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/item-types/:id",
              "host": ["{{baseUrl}}"],
              "path": ["item-types", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{itemTypeId}}",
                  "description": "Item Type UUID"
                }
              ]
            },
            "description": "Get a specific item type by ID"
          },
          "response": []
        },
        {
          "name": "Create Item Type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gold Anklet\",\n  \"description\": \"Gold anklets and foot jewelry\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/item-types",
              "host": ["{{baseUrl}}"],
              "path": ["item-types"]
            },
            "description": "Create a new item type"
          },
          "response": []
        },
        {
          "name": "Update Item Type",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gold Anklet\",\n  \"description\": \"Updated description - Gold anklets and foot jewelry\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/item-types/:id",
              "host": ["{{baseUrl}}"],
              "path": ["item-types", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{itemTypeId}}",
                  "description": "Item Type UUID"
                }
              ]
            },
            "description": "Update an existing item type"
          },
          "response": []
        },
        {
          "name": "Toggle Item Type Active Status",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/item-types/:id/toggle-active",
              "host": ["{{baseUrl}}"],
              "path": ["item-types", ":id", "toggle-active"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{itemTypeId}}",
                  "description": "Item Type UUID"
                }
              ]
            },
            "description": "Toggle the active status of an item type"
          },
          "response": []
        },
        {
          "name": "Delete Item Type",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/item-types/:id",
              "host": ["{{baseUrl}}"],
              "path": ["item-types", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{itemTypeId}}",
                  "description": "Item Type UUID"
                }
              ]
            },
            "description": "Delete an item type (soft delete)"
          },
          "response": []
        }
      ]
    },
