# Supabase Configuration
NEXT_PUBLIC_SUPABASE_PROJECT_ID="your-supabase-project-id"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080/api"

# Color Theme Variables (HSL format) - Optional, falls back to CSS defaults
# Light Mode Colors
NEXT_PUBLIC_COLOR_BACKGROUND_LIGHT="0 0% 98%"
NEXT_PUBLIC_COLOR_FOREGROUND_LIGHT="215 25% 12%"
NEXT_PUBLIC_COLOR_CARD_LIGHT="0 0% 100%"
NEXT_PUBLIC_COLOR_PRIMARY_LIGHT="217 91% 60%"
NEXT_PUBLIC_COLOR_PRIMARY_FOREGROUND_LIGHT="0 0% 100%"
NEXT_PUBLIC_COLOR_SECONDARY_LIGHT="215 24% 25%"
NEXT_PUBLIC_COLOR_SECONDARY_FOREGROUND_LIGHT="0 0% 100%"
NEXT_PUBLIC_COLOR_MUTED_LIGHT="215 16% 47%"
NEXT_PUBLIC_COLOR_MUTED_FOREGROUND_LIGHT="215 13% 34%"
NEXT_PUBLIC_COLOR_BORDER_LIGHT="215 20% 92%"
NEXT_PUBLIC_COLOR_SIDEBAR_BACKGROUND_LIGHT="215 24% 25%"
NEXT_PUBLIC_COLOR_SIDEBAR_FOREGROUND_LIGHT="0 0% 95%"
NEXT_PUBLIC_COLOR_SIDEBAR_PRIMARY_LIGHT="217 91% 60%"
NEXT_PUBLIC_COLOR_ACCENT_LIGHT="217 91% 60%"

# Dark Mode Colors
NEXT_PUBLIC_COLOR_BACKGROUND_DARK="215 28% 14%"
NEXT_PUBLIC_COLOR_FOREGROUND_DARK="0 0% 95%"
NEXT_PUBLIC_COLOR_CARD_DARK="215 28% 18%"
NEXT_PUBLIC_COLOR_PRIMARY_DARK="217 91% 60%"
NEXT_PUBLIC_COLOR_PRIMARY_FOREGROUND_DARK="215 28% 14%"
NEXT_PUBLIC_COLOR_SECONDARY_DARK="215 20% 65%"
NEXT_PUBLIC_COLOR_SECONDARY_FOREGROUND_DARK="215 28% 14%"
NEXT_PUBLIC_COLOR_MUTED_DARK="215 18% 40%"
NEXT_PUBLIC_COLOR_MUTED_FOREGROUND_DARK="215 15% 58%"
NEXT_PUBLIC_COLOR_BORDER_DARK="215 30% 35%"
NEXT_PUBLIC_COLOR_SIDEBAR_BACKGROUND_DARK="215 24% 20%"
NEXT_PUBLIC_COLOR_SIDEBAR_FOREGROUND_DARK="0 0% 90%"
NEXT_PUBLIC_COLOR_SIDEBAR_PRIMARY_DARK="217 91% 60%"
NEXT_PUBLIC_COLOR_ACCENT_DARK="217 91% 60%"

# Semantic Colors (for alerts, success, warning, etc.)
NEXT_PUBLIC_COLOR_DESTRUCTIVE="0 84.2% 60.2%"
NEXT_PUBLIC_COLOR_SUCCESS="16 100% 38%"
NEXT_PUBLIC_COLOR_WARNING="38 92% 50%"
NEXT_PUBLIC_COLOR_INFO="217 91% 60%"
