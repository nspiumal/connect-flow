# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key"
VITE_SUPABASE_URL="your_supabase_url"

# Backend API Configuration
VITE_API_BASE_URL="http://localhost:8080/api"

# Color Theme Variables (HSL format: hue saturation% lightness%)
# Light Mode Colors
VITE_COLOR_BACKGROUND_LIGHT="0 0% 98%"
VITE_COLOR_FOREGROUND_LIGHT="215 25% 12%"
VITE_COLOR_CARD_LIGHT="0 0% 100%"
VITE_COLOR_PRIMARY_LIGHT="217 91% 60%"
VITE_COLOR_PRIMARY_FOREGROUND_LIGHT="0 0% 100%"
VITE_COLOR_SECONDARY_LIGHT="215 24% 25%"
VITE_COLOR_SECONDARY_FOREGROUND_LIGHT="0 0% 100%"
VITE_COLOR_MUTED_LIGHT="215 16% 47%"
VITE_COLOR_MUTED_FOREGROUND_LIGHT="215 13% 34%"
VITE_COLOR_BORDER_LIGHT="215 20% 92%"
VITE_COLOR_SIDEBAR_BACKGROUND_LIGHT="215 24% 25%"
VITE_COLOR_SIDEBAR_FOREGROUND_LIGHT="0 0% 95%"
VITE_COLOR_SIDEBAR_PRIMARY_LIGHT="217 91% 60%"
VITE_COLOR_ACCENT_LIGHT="217 91% 60%"

# Dark Mode Colors
VITE_COLOR_BACKGROUND_DARK="215 28% 14%"
VITE_COLOR_FOREGROUND_DARK="0 0% 95%"
VITE_COLOR_CARD_DARK="215 28% 18%"
VITE_COLOR_PRIMARY_DARK="217 91% 60%"
VITE_COLOR_PRIMARY_FOREGROUND_DARK="215 28% 14%"
VITE_COLOR_SECONDARY_DARK="215 20% 65%"
VITE_COLOR_SECONDARY_FOREGROUND_DARK="215 28% 14%"
VITE_COLOR_MUTED_DARK="215 18% 40%"
VITE_COLOR_MUTED_FOREGROUND_DARK="215 15% 58%"
VITE_COLOR_BORDER_DARK="215 30% 35%"
VITE_COLOR_SIDEBAR_BACKGROUND_DARK="215 24% 20%"
VITE_COLOR_SIDEBAR_FOREGROUND_DARK="0 0% 90%"
VITE_COLOR_SIDEBAR_PRIMARY_DARK="217 91% 60%"
VITE_COLOR_ACCENT_DARK="217 91% 60%"

# Semantic Colors (for alerts, success, warning, etc.)
VITE_COLOR_DESTRUCTIVE="0 84.2% 60.2%"
VITE_COLOR_SUCCESS="16 100% 38%"
VITE_COLOR_WARNING="38 92% 50%"
VITE_COLOR_INFO="217 91% 60%"

# ===== COLOR VALUE REFERENCE =====
# HSL Format: hue (0-360) saturation% (0-100) lightness% (0-100)
#
# Light Mode Presets:
#   Professional Blue: 217 91% 60%
#   Dark Slate: 215 24% 25%
#   Light Background: 0 0% 98%
#
# Dark Mode Presets:
#   Deep Blue-Gray: 215 28% 14%
#   Card Background: 215 28% 18%
#   Light Text: 0 0% 95%
#
# Semantic Colors:
#   Success (Green): 16 100% 38%
#   Warning (Amber): 38 92% 50%
#   Destructive (Red): 0 84.2% 60.2%
#   Info (Blue): 217 91% 60%

